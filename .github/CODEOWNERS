/frontend/src/services/security.ts @efvm360-team/security
/frontend/src/services/permissions.ts @efvm360-team/security

# CI/CD changes require DevOps review
/.github/ @efvm360-team/devops
/docker-compose.yml @efvm360-team/devops
/backend/Dockerfile @efvm360-team/devops

# Database migrations require DBA review
/backend/src/migrations/ @efvm360-team/dba
/backend/docs/init.sql @efvm360-team/dba
