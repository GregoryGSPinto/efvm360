# ============================================================================
# VFZ BACKEND — Variáveis de Ambiente
# Copie para .env para uso local
# Em Azure: configure via App Service > Configuration > Application Settings
# ============================================================================

# ── Servidor ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
API_PREFIX=/api/v1

# ── MySQL Local ───────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=vfz_railway
DB_USER=vfz_app
DB_PASSWORD=ALTERAR_SENHA_SEGURA_AQUI

# ── Azure SQL for MySQL (produção) ────────────────────────────────────────
# DB_HOST=vfz-mysql.mysql.database.azure.com
# DB_PORT=3306
# DB_NAME=vfz_railway
# DB_USER=vfz_admin@vfz-mysql
# DB_PASSWORD=SUA_SENHA_AZURE
# DB_SSL=true

# ── JWT ───────────────────────────────────────────────────────────────────
JWT_SECRET=ALTERAR_GERAR_COM_openssl_rand_base64_64
JWT_REFRESH_SECRET=ALTERAR_GERAR_COM_openssl_rand_base64_64
JWT_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=7d

# ── Segurança ─────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# ── CORS ──────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173

# ── Azure Application Insights (produção) ─────────────────────────────────
# APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=xxx;...

# ── Azure AD / Entra ID (SSO corporativo — futuro) ───────────────────────
# AZURE_AD_TENANT_ID=
# AZURE_AD_CLIENT_ID=
# AZURE_AD_CLIENT_SECRET=
