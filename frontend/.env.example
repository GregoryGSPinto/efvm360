# ============================================================================
# EFVM360 — Variáveis de Ambiente (Frontend)
# Copie para .env.local para uso local
# ============================================================================

# Backend API URL (quando disponível)
VITE_API_URL=http://localhost:3001/api/v1
# Exemplo de produção: VITE_API_URL=https://api.example.com/api/v1

# Ambiente: development | staging | production
VITE_ENV=development

# Ativar comunicação com backend (false = localStorage, true = API HTTP)
VITE_USE_BACKEND=false

# Sincronizar audit trail com backend (requer API)
VITE_AUDIT_SYNC=false

# Timeout de sessão em minutos
VITE_SESSION_TIMEOUT=30

# Máximo de tentativas de login antes de lockout
VITE_MAX_LOGIN_ATTEMPTS=5

# Duração do lockout em minutos
VITE_LOCKOUT_MINUTES=15

# Mostrar painel de credenciais demo na tela de login
VITE_SHOW_DEMO_CREDENTIALS=false
