{
  "name": "passagem-servico-efvm360",
  "packageManager": "pnpm@10.30.1",
  "version": "2.0.0",
  "description": "Sistema Digital de Gestão de Troca de Turno Ferroviária - EFVM360",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "clean": "rimraf node_modules/.vite dist",
    "fresh": "rimraf node_modules/.vite dist && vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run __tests__/services __tests__/hooks",
    "test:services": "vitest run __tests__/services",
    "test:hooks": "vitest run __tests__/hooks"
  },
  "dependencies": {
    "@capacitor/core": "^8.1.0",
    "@capacitor/network": "^8.0.1",
    "d3": "^7.9.0",
    "echarts": "^5.5.0",
    "html2canvas": "^1.4.1",
    "i18next": "^25.8.14",
    "i18next-browser-languagedetector": "^8.2.1",
    "jspdf": "^4.2.0",
    "lucide-react": "^0.575.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-i18next": "^16.5.4",
    "react-router-dom": "^7.13.1",
    "recharts": "^3.7.0",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.1.0",
    "@types/d3": "^7.4.3",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^6.14.0",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/coverage-v8": "^2.0.0",
    "eslint": "^8.55.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "jsdom": "^24.0.0",
    "rimraf": "^6.1.3",
    "typescript": "^5.2.2",
    "vite": "^5.0.8",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^2.0.0",
    "workbox-cacheable-response": "^7.4.0",
    "workbox-expiration": "^7.4.0",
    "workbox-precaching": "^7.4.0",
    "workbox-routing": "^7.4.0",
    "workbox-strategies": "^7.4.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "author": "EFVM360 - Vale Ferrovia",
  "license": "PROPRIETARY"
}
